{
  "entities": {
    "UserRequest": {
      "title": "User Request",
      "description": "A request for student portal access",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "studentId": { "type": "string" }
      },
      "required": ["id", "name", "email", "status", "createdAt"]
    },
    "AdminConfig": {
      "title": "Admin Configuration",
      "description": "Global configuration for the admin panel",
      "type": "object",
      "properties": {
        "adminPassword": { "type": "string" }
      },
      "required": ["adminPassword"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Student feedback or issue report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentName": { "type": "string" },
        "studentEmail": { "type": "string", "format": "email" },
        "type": { "type": "string", "enum": ["suggestion", "issue"] },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentName", "studentEmail", "type", "message", "createdAt"]
    }
  },
  "firestore": {
    "/requests/{requestId}": {
      "schema": "UserRequest",
      "description": "Collection of student access requests"
    },
    "/config/admin": {
      "schema": "AdminConfig",
      "description": "Admin configuration document"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of student feedback and issue reports"
    }
  }
}
